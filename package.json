{
  "name": "dream-list",
  "version": "1.0.0",
  "description": "API REST sencilla para gestionar una lista de sueños. En esta clase aprenderás a crear un servidor con **Node.js** y **Express**, y a manejar las operaciones CRUD básicas.",
  "main": "index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "nodemon --watch src --ext ts --exec \"tsc && node dist/index.js\"",
    "categoriesSeed": "tsx src/api/categories/categories.seed.js",
    "comicsSeed": "tsx src/api/comics/comics.seed.js",
    "usersSeed": "tsx src/api/users/users.seed.js",
    "collectionsSeed": "tsx src/api/usersCollection/usersCollection.seed.js",
    "vinylsSeed": "tsx src/api/vinyls/vinyls.seed.js"
  },
  "keywords": [],
  "author": "Laura Gavilán",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "mongoose": "^9.4.1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Eleven-Code-School/codigo-clase-node-2-tu-primera-api.git"
  },
  "bugs": {
    "url": "https://github.com/Eleven-Code-School/codigo-clase-node-2-tu-primera-api/issues"
  },
  "homepage": "https://github.com/Eleven-Code-School/codigo-clase-node-2-tu-primera-api#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "eslint": "^10.1.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.4.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2"
  }
}
